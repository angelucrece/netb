# ── Serveur ────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN=*

# ── PostgreSQL ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nethastock
DB_USERNAME=postgres
DB_PASSWORD=your_password

# ── JWT ────────────────────────────────────────────────────
JWT_SECRET=change_me_minimum_32_characters_long_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_another_32_characters_secret
JWT_REFRESH_EXPIRES_IN=7d

# ── Rate Limiting ──────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ── Logs ───────────────────────────────────────────────────
LOG_LEVEL=info

# ── Upload ─────────────────────────────────────────────────
UPLOAD_MAX_SIZE_MB=5

# ── Firebase (notifications push – optionnel) ──────────────
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
